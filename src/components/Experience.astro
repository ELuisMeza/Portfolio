---
import { all_experiences } from "../data/experiencies";
import { renderWithStrong } from "../utils/transformStrong";
---

<section id="experience" aria-label="Experiencia">
  <div
    class="sticky top-0 z-30 w-screen py-3 backdrop-blur-xl md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
  >
    <h2 class="text-lg font-bold uppercase tracking-widest text-neutral-200">
      Experiencia
    </h2>
  </div>

  <div class="w-full flex flex-col gap-6 mt-7 max-w-[800px] mx-auto">
    {
      all_experiences.map((experience) => {
        return (
          <div class="flex flex-col lg:flex-row items-start gap-4 bg-color-hover rounded-xl p-6 shadow-md lg:bg-transparent lg:border-2 lg:border-color-hover lg:hover:bg-color-hover duration-150">
            <img
              src={`/imgs/experience/${experience.image}`}
              alt={experience.companyName}
              class="w-16 h-16 object-cover rounded-lg shadow-sm"
            />

            <div class="flex flex-col gap-2 text-sm">
              <div>
                <h3 class="text-base font-bold text-neutral-100">
                  {experience.title}
                </h3>
                <p class="text-neutral-300">
                  {experience.companyName} <br />
                  <span class="text-xs text-neutral-400">
                    ({experience.time})
                  </span>
                </p>
              </div>

              <p class="text-neutral-400 leading-relaxed">
                {experience.description}
              </p>

              <ul class="list-disc list-inside text-neutral-400 pl-1 space-y-1">
                {experience.activities.map((responsibility) => {
                  return <li set:html={renderWithStrong(responsibility)}></li>;
                })}
              </ul>
            </div>
          </div>
        );
      })
    }
  </div>
</section>

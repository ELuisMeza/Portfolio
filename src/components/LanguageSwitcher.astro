---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "../i18n/types";
import { getT } from "../i18n/server";

interface Props {
  locale: Locale;
  variant?: "corner" | "inline";
}

const { locale, variant = "inline" } = Astro.props;
const t = getT(locale);
const esHref = getRelativeLocaleUrl("es", "/");
const enHref = getRelativeLocaleUrl("en", "/");

const navClass =
  variant === "corner"
    ? "inline-flex items-center"
    : "mt-6 flex flex-wrap items-center justify-center gap-2 lg:justify-start";

const segmentClass =
  variant === "corner"
    ? "inline-flex rounded-md border border-neutral-600/35 bg-neutral-950/50 p-px text-[10px] font-medium leading-none backdrop-blur-sm"
    : "inline-flex rounded-lg border border-neutral-700/60 bg-neutral-400/10 p-0.5 text-xs font-medium";

const linkBaseCorner =
  "min-w-[1.75rem] rounded px-1.5 py-1 text-center tabular-nums transition-colors";
const linkBaseInline = "rounded-md px-3 py-1.5 transition-colors";
---

<nav class={navClass} aria-label={t("language.label")}>
  {
    variant === "inline" && (
      <span class="text-xs text-neutral-500 uppercase tracking-wider">
        {t("language.label")}
      </span>
    )
  }
  {
    variant === "corner" && (
      <span class="sr-only">{t("language.label")}</span>
    )
  }
  <div class={segmentClass}>
    <a
      href={esHref}
      hreflang="es"
      lang="es"
      title={t("language.es")}
      class:list={[
        variant === "corner" ? linkBaseCorner : linkBaseInline,
        locale === "es"
          ? "bg-neutral-200 text-neutral-900"
          : "text-neutral-500 hover:text-neutral-300",
      ]}
      aria-current={locale === "es" ? "page" : undefined}
      >{variant === "corner" ? "ES" : t("language.es")}</a
    >
    <a
      href={enHref}
      hreflang="en"
      lang="en"
      title={t("language.en")}
      class:list={[
        variant === "corner" ? linkBaseCorner : linkBaseInline,
        locale === "en"
          ? "bg-neutral-200 text-neutral-900"
          : "text-neutral-500 hover:text-neutral-300",
      ]}
      aria-current={locale === "en" ? "page" : undefined}
      >{variant === "corner" ? "EN" : t("language.en")}</a
    >
  </div>
</nav>

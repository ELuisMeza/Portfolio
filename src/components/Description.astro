---
import "../styles/globals.css";
import type { Locale } from "../i18n/types";
import { getT } from "../i18n/server";
import { renderWithStrong } from "../utils/transformStrong";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getT(locale);
---

<section id="about" aria-label={t("about.aria")}>
  <div class="sticky top-0 z-30 w-screen py-3 backdrop-blur-xl lg:hidden">
    <h2 class="text-lg font-bold uppercase tracking-widest text-neutral-200">
      {t("about.title")}
    </h2>
  </div>
  <p class="text-sm leading-relaxed lg:leading-[1.75]">
    <span set:html={renderWithStrong(t("about.p1"), "resalt-text")} />
    <br />
    <span set:html={renderWithStrong(t("about.p2"), "resalt-text")} />
    <br />
    <span set:html={renderWithStrong(t("about.p3"), "resalt-text")} />
  </p>
</section>

---
import { ProjectCard } from "./ProjectCard";
import { getT } from "../i18n/server";

const {
  locale,
  title,
  description,
  technologies,
  demoURL,
  repoURL,
  image,
  imagesDetail,
} = Astro.props;

const t = getT(locale);
---

<ProjectCard
  client:load
  title={title}
  description={description}
  technologies={technologies}
  demoURL={demoURL}
  repoURL={repoURL}
  image={image}
  imagesDetail={imagesDetail}
  labels={{
    demo: t("projectCard.demo"),
    repository: t("projectCard.repository"),
    close: t("projectCard.close"),
    closeModalAria: t("projectCard.closeModalAria"),
    technologiesAria: t("projectCard.technologiesAria"),
  }}
  carouselLabels={{
    empty: t("carousel.empty"),
    prevAria: t("carousel.prevAria"),
    nextAria: t("carousel.nextAria"),
    goToPrefix: t("carousel.goToPrefix"),
    prev: t("carousel.prev"),
    next: t("carousel.next"),
    defaultAlt: t("carousel.defaultAlt"),
  }}
/>
